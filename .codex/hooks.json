{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.agents/hooks/adapters/codex-pretool-generated-files.sh\"",
            "statusMessage": "Checking generated-file policy"
          }
        ]
      }
    ]
  }
}
